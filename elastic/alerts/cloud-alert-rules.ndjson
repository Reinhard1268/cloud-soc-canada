#cloud-alert-rules.ndjson

{"id":"guardduty-high-critical-alert","name":"GuardDuty High/Critical Finding","tags":["cloud","aws","guardduty"],"rule_type_id":".es-query","consumer":"siem","schedule":{"interval":"5m"},"params":{"size":100,"index":["aws-guardduty-findings"],"timeField":"@timestamp","esQuery":"{\"query\":{\"bool\":{\"must\":[{\"range\":{\"@timestamp\":{\"gte\":\"now-5m\"}}},{\"terms\":{\"aws.guardduty.severity_label\":[\"high\",\"critical\"]}}]}}}"},"actions":[{"id":"default-action","group":"default","params":{"subject":"[SOC Alert] GuardDuty {{context.hits.total.value}} High/Critical Finding(s)","message":"GuardDuty detected {{context.hits.total.value}} high/critical findings in ca-central-1. Check Kibana dashboard for details."}}],"notify_when":"onActiveAlert","throttle":"1h"}
{"id":"cloudtrail-root-usage-alert","name":"AWS Root Account Usage Detected","tags":["cloud","aws","critical","root"],"rule_type_id":".es-query","consumer":"siem","schedule":{"interval":"1m"},"params":{"size":10,"index":["aws-cloudtrail-events"],"timeField":"@timestamp","esQuery":"{\"query\":{\"bool\":{\"must\":[{\"range\":{\"@timestamp\":{\"gte\":\"now-1m\"}}},{\"term\":{\"aws.cloudtrail.user_identity.type\":\"Root\"}}]}}}"},"actions":[{"id":"default-action","group":"default","params":{"subject":"[CRITICAL SOC Alert] AWS Root Account Used","message":"Root account activity detected in CloudTrail. Immediate investigation required. Account: {{context.hits.hits.0._source.cloud.account.id}}"}}],"notify_when":"onActiveAlert","throttle":"1h"}
{"id":"azure-global-admin-assigned-alert","name":"Azure Global Admin Role Assigned","tags":["cloud","azure","critical","iam"],"rule_type_id":".es-query","consumer":"siem","schedule":{"interval":"5m"},"params":{"size":10,"index":["azure-sentinel-alerts"],"timeField":"@timestamp","esQuery":"{\"query\":{\"bool\":{\"must\":[{\"range\":{\"@timestamp\":{\"gte\":\"now-5m\"}}},{\"term\":{\"event.action\":\"Add member to role\"}},{\"wildcard\":{\"azure.auditlogs.operation_name\":\"*Global Administrator*\"}}]}}}"},"actions":[{"id":"default-action","group":"default","params":{"subject":"[CRITICAL SOC Alert] Azure Global Admin Role Assigned","message":"A Global Administrator role was assigned in Azure AD. User: {{context.hits.hits.0._source.user.name}}. Review immediately."}}],"notify_when":"onActiveAlert","throttle":"1h"}
{"id":"cloudtrail-logging-disabled-alert","name":"CloudTrail Logging Disabled","tags":["cloud","aws","defense-evasion"],"rule_type_id":".es-query","consumer":"siem","schedule":{"interval":"1m"},"params":{"size":5,"index":["aws-cloudtrail-events"],"timeField":"@timestamp","esQuery":"{\"query\":{\"bool\":{\"must\":[{\"range\":{\"@timestamp\":{\"gte\":\"now-1m\"}}},{\"term\":{\"event.action\":\"StopLogging\"}},{\"term\":{\"event.outcome\":\"success\"}}]}}}"},"actions":[{"id":"default-action","group":"default","params":{"subject":"[CRITICAL SOC Alert] CloudTrail Logging Stopped","message":"CloudTrail StopLogging API called successfully. Trail may be disabled. Investigate immediately — possible cover of tracks."}}],"notify_when":"onActiveAlert","throttle":"30m"}
{"id":"brute-force-azure-alert","name":"Azure AD Brute Force Detected","tags":["cloud","azure","brute-force"],"rule_type_id":".es-query","consumer":"siem","schedule":{"interval":"5m"},"params":{"size":100,"index":["azure-sentinel-alerts"],"timeField":"@timestamp","esQuery":"{\"query\":{\"bool\":{\"must\":[{\"range\":{\"@timestamp\":{\"gte\":\"now-10m\"}}},{\"term\":{\"event.outcome\":\"failure\"}}]}}}"},"actions":[{"id":"default-action","group":"default","params":{"subject":"[SOC Alert] Azure AD Brute Force Detected","message":"Multiple failed Azure AD login attempts detected. Check for password spray or brute force attacks."}}],"notify_when":"onActiveAlert","throttle":"30m"}
{"id":"crypto-mining-alert","name":"Crypto Mining Activity Detected","tags":["cloud","crypto-mining","t1496"],"rule_type_id":".es-query","consumer":"siem","schedule":{"interval":"15m"},"params":{"size":10,"index":["aws-guardduty-findings","azure-sentinel-alerts"],"timeField":"@timestamp","esQuery":"{\"query\":{\"bool\":{\"must\":[{\"range\":{\"@timestamp\":{\"gte\":\"now-15m\"}}},{\"bool\":{\"should\":[{\"wildcard\":{\"aws.guardduty.finding_type\":\"CryptoCurrency:*\"}},{\"match\":{\"aws.guardduty.finding_type\":\"CryptoMining\"}},{\"match\":{\"event.action\":\"Crypto Mining Activity Detected\"}}]}}]}}}"},"actions":[{"id":"default-action","group":"default","params":{"subject":"[SOC Alert] Crypto Mining Detected in Cloud","message":"Cryptocurrency mining activity detected. Possible resource hijacking (T1496). Check affected instances immediately."}}],"notify_when":"onActiveAlert","throttle":"2h"}
