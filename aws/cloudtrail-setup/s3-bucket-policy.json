{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AWSCloudTrailAclCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID",
      "Condition": {
        "StringEquals": {
          "aws:SourceArn": "arn:aws:cloudtrail:ca-central-1:ACCOUNT_ID:trail/soc-lab-trail"
        }
      }
    },
    {
      "Sid": "AWSCloudTrailWrite",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudtrail.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID/cloudtrail/AWSLogs/ACCOUNT_ID/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control",
          "aws:SourceArn": "arn:aws:cloudtrail:ca-central-1:ACCOUNT_ID:trail/soc-lab-trail"
        }
      }
    },
    {
      "Sid": "DenyNonSSLRequests",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID",
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID/*"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    },
    {
      "Sid": "DenyPublicReadACL",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:PutBucketAcl",
        "s3:PutObjectAcl",
        "s3:PutObjectVersionAcl"
      ],
      "Resource": [
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID",
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID/*"
      ],
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": [
            "public-read",
            "public-read-write",
            "authenticated-read"
          ]
        }
      }
    },
    {
      "Sid": "AllowSOCRoleReadLogs",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::ACCOUNT_ID:role/SOC-ReadOnly-Role"
      },
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID",
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID/*"
      ]
    },
    {
      "Sid": "DenyDeleteByAnyone",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:DeleteBucket",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": [
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID",
        "arn:aws:s3:::soc-lab-cloudtrail-logs-ca-ACCOUNT_ID/*"
      ],
      "Condition": {
        "StringNotEquals": {
          "aws:PrincipalArn": "arn:aws:iam::ACCOUNT_ID:root"
        }
      }
    }
  ]
}
